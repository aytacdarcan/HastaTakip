    bool addingDiyet = false;
    DiyetCreateDto diyetAdd = new() { Tarih = DateTime.Today };

    void ToggleAddDiyet()
    {
        addingDiyet = !addingDiyet;
        localError = null;
        if (addingDiyet)
            diyetAdd = new DiyetCreateDto { Tarih = DateTime.Today };
    }

    async Task SaveAddDiyet()
    {
        try
        {
            if (diyetAdd.Tarih == default)
            {
                localError = "Tarih zorunludur.";
                return;
            }

            diyetAdd.HastaID = bundle?.Hasta.Id ?? id;
            await Api.CreateDiyetAsync(diyetAdd);
            bundle = await Api.GetPatientBundleAsync(id);
            addingDiyet = false;
            localError = null;
            StateHasChanged();
        }
        catch (Exception ex) { localError = ex.Message; }
    }

    void StartEditDiyet(DiyetListDto d)
    {
        localError = null;
        if (!diyetEdits.ContainsKey(d.DiyetID))
        {
            diyetEdits[d.DiyetID] = new DiyetUpdateDto
            {
                Tarih = d.Tarih,
                Ekmek = d.Ekmek,
                Tahil = d.Tahil,

                Et = d.Et,
                Peynir = d.Peynir,

                Sut = d.Sut,
                Yogurt = d.Yogurt,

                Meyve = d.Meyve,
                Sebze = d.Sebze,

                SiviGida = d.SiviGida,
                AburCubur = d.AburCubur,
                EkranSuresi = d.EkranSuresi
            };
        }
    }

    void CancelEditDiyet(int diyetId)
    {
        diyetEdits.Remove(diyetId);
        localError = null;
    }

    async Task SaveEditDiyet(int diyetId)
    {
        if (!diyetEdits.TryGetValue(diyetId, out var dto)) return;
        try
        {
            await Api.UpdateDiyetAsync(diyetId, dto);
            diyetEdits.Remove(diyetId);
            bundle = await Api.GetPatientBundleAsync(id);
            localError = null;
            StateHasChanged();
        }
        catch (Exception ex) { localError = ex.Message; }
    }

    async Task DeleteDiyet(int diyetId)
    {
        if (!await ConfirmAsync("Bu diyet kaydını silmek istediğinize emin misiniz?")) return;
        try
        {
            await Api.DeleteDiyetAsync(diyetId);
            bundle = await Api.GetPatientBundleAsync(id);
            StateHasChanged();
        }
        catch (Exception ex) { localError = ex.Message; }
    }

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        error = null;

        try
        {
            bundle = await Api.GetPatientBundleAsync(id);

            if (bundle is null)
            {
                error = "Hasta kaydı bulunamadı.";
            }
            else
            {
               
                await LoadVisits();
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }

        loading = false;
    }


