@page "/ziyaretler/yeni/{hastaId:int}"
@using HastaTakip.UI.Dtos
@inject HastaTakip.UI.Services.HastaApi Api
@inject NavigationManager Nav
@rendermode InteractiveServer

<h3>Yeni Ziyaret</h3>

@if (saving)
{
    <p>Kaydediliyor…</p>
}
else
{
    <section class="section-card">
        <h5 class="sec-title">Ziyaret</h5>
        <div class="form-grid">
            <label class="col-span-3">
                Yakınmalar
                <textarea class="input-textarea" rows="2" @bind="bundle.Ziyaret.YakinmalarZiyaret"></textarea>
            </label>

            <label class="col-span-3">
                Tarih
                <input class="input-text" type="date" @bind="bundle.Ziyaret.Tarih" />
            </label>

            <label class="col-span-6">
                Notlar
                <textarea class="input-textarea" rows="2" @bind="bundle.Ziyaret.Notlar"></textarea>
            </label>
        </div>
    </section>


    <section class="section-card">
        <h5 class="sec-title">Antropometri <small>(opsiyonel)</small></h5>
        <div class="form-grid">
            <label>
                Boy (cm)
                <input class="input-text" type="number" step="0.01" @bind="bundle.Antropometri!.BoyCm" />
            </label>
            <label>
                Kilo (kg)
                <input class="input-text" type="number" step="0.01" @bind="bundle.Antropometri!.KiloKg" />
            </label>
            <label>
                Baş çev. (cm)
                <input class="input-text" type="number" step="0.01" @bind="bundle.Antropometri!.BasCevresiCm" />
            </label>
            <label>
                Oturma boyu
                <input class="input-text" type="number" step="0.01" @bind="bundle.Antropometri!.OturmaBoyuCm" />
            </label>
        </div>
    </section>

    <section class="section-card">
        <h5 class="sec-title">Puberte <small>(opsiyonel)</small></h5>
        <div class="form-grid">
            <label>
                Not
                <input class="input-text" @bind="bundle.Puberte!.PuberteNotu" />
            </label>
            <label>
                Patolojik Fizik
                <input class="input-text" @bind="bundle.Puberte!.PatolojikFizik" />
            </label>
        </div>
    </section>

    <section class="section-card">
        <h5 class="sec-title">Yorum/Plan <small>(opsiyonel)</small></h5>
        <div class="form-grid">
            <label class="col-span-3">
                Tedavi/Beslenme/Spor
                <textarea class="input-textarea" rows="3" @bind="bundle.YorumPlan!.TedaviBeslenmeSpor"></textarea>
            </label>
            <label class="col-span-3">
                Notlar
                <textarea class="input-textarea" rows="3" @bind="bundle.YorumPlan!.YorumNotlar"></textarea>
            </label>
        </div>
    </section>

    <section class="section-card">
        <h5 class="sec-title">Özet <small>(opsiyonel)</small></h5>
        <div class="form-grid">
            <label>
                Hedef Boy
                <input class="input-text" type="number" step="0.01" @bind="bundle.Ozet!.HedefBoyCm" />
            </label>
            <label>
                Kulaç
                <input class="input-text" type="number" step="0.01" @bind="bundle.Ozet!.KulacCm" />
            </label>
            <label>
                Boy’a Uyan Tartı
                <input class="input-text" @bind="bundle.Ozet!.BoyaUyanTarti" />
            </label>
        </div>
    </section>

    <div class="row-actions" style="margin-bottom:2rem">
        <button type="button" class="btn-blue" @onclick="Kaydet">Kaydet</button>
        <button type="button" class="btn-secondary" @onclick="Geri">Vazgeç</button>
        <span class="err">@error</span>
    </div>

}

@code {
    [Parameter] public int hastaId { get; set; }
    ZiyaretBundleCreateDto bundle = new();
    bool saving; string? error;

    protected override void OnParametersSet()
    {
        bundle = new ZiyaretBundleCreateDto
        {
            Ziyaret = new ZiyaretCreateDto { HastaID = hastaId, Tarih = DateTime.Today },
            Antropometri = new AntropometriCreateDto(),
            Puberte = new PuberteFizikCreateDto(),
            YorumPlan = new YorumPlanCreateDto(),
            Ozet = new OzetHesapCreateDto()
        };
    }

    async Task Kaydet()
    {
        try
        {
            saving = true; error = null;
            var id = await Api.CreateVisitBundleAsync(bundle);
            Nav.NavigateTo($"/ziyaretler/{id}");
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; }
    }

    void Geri() => Nav.NavigateTo($"/hastalar/{hastaId}");
}
<style>
    .col-span-6 {
        grid-column: span 6
    }

    .section-card {
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 12px;
        background: #fff;
        margin-bottom: 12px
    }

    .sec-title {
        margin: 0 0 .5rem 0;
        font-weight: 700
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(6,minmax(0,1fr));
        gap: .75rem;
        align-items: start
    }

    .col-span-3 {
        grid-column: span 3
    }

    .row-actions {
        display: flex;
        gap: .5rem;
        align-items: center
    }

    .input-text, .input-textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #cfd4dc;
        border-radius: 8px;
        background: #fff;
        font-size: .95rem;
        color: #1f2937;
        transition: border-color .2s,box-shadow .2s
    }

        .input-text:focus, .input-textarea:focus {
            outline: none;
            border-color: #1976d2;
            box-shadow: 0 0 0 3px rgba(25,118,210,.15)
        }

    .input-textarea {
        min-height: 96px;
        resize: vertical
    }

    .btn-blue {
        background: #1976d2;
        color: #fff;
        border: none;
        padding: 8px 14px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer
    }

        .btn-blue:hover {
            background: #145da3
        }

    .btn-secondary {
        background: #6c757d;
        color: #fff;
        border: none;
        padding: 8px 14px;
        border-radius: 8px;
        cursor: pointer
    }

        .btn-secondary:hover {
            background: #5a6268
        }

    .err {
        color: #b00020;
        margin-left: .5rem
    }

    @@media (max-width: 992px) {
        .form-grid {
            grid-template-columns: repeat(2,minmax(0,1fr))
        }

        .col-span-3 {
            grid-column: span 2
        }
    }
</style>

