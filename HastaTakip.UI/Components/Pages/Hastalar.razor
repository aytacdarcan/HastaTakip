@page "/hastalar"
@rendermode InteractiveServer
@using HastaTakip.UI.Dtos
@using HastaTakip.UI.Services
@using Microsoft.AspNetCore.Components.Web
@inject HastaApi Api
@inject NavigationManager Nav

<h3>Hastalar</h3>

<div style="margin-bottom:.75rem; display:flex; gap:.5rem; align-items:center;">
    <input type="text" placeholder="İsim / TCKN..."
           @bind-value="q"
           @oninput="OnSearchInput"
           @onkeydown="OnKeyDown"
           style="width:240px;" />
    <button type="button" @onclick="Search">Ara</button>

    
    <a href="/hastalar/yeni" class="btn-add" style="margin-left:.5rem;">+ Yeni Hasta</a>
</div>



<style>
    
    a {
        color: #0074cc;
        font-weight: 500; 
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
            color: #005fa3;
        }



    .btn-add {
        background-color: #28a745;
        color: #fff;
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: background-color .2s;
    }

        .btn-add:hover {
            background-color: #218838;
        }

    
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

   
    th {
        text-align: left;
        padding: 10px;
        font-weight: 600;
        color: #222;
        border-bottom: 1px solid #ddd;
    }

    
    td {
        padding: 10px;
        font-size: 15px;
        color: #111;
        border-bottom: 1px solid #eee;
        font-weight: 550; 
    }


    
    tbody tr:nth-child(even) {
        background-color: #fafafa;
    }

    
    tr:hover td {
        background-color: #f2f2f2;
    }

    
    h3 {
        font-weight: 500;
        color: #222;
        margin-bottom: .75rem;
    }



    input[type="text"] {
        padding: 4px 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    button {
        background-color: #1976d2;
        color: #fff;
        border: none;
        padding: 5px 10px;
        border-radius: 4px;
        cursor: pointer;
    }

        button:hover {
            background-color: #135ca8;
        }
</style>




@if (loading)
{
    <p>Yükleniyor...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red">Error: @error</p>
}
else
{
    <table style="border-collapse:collapse; width:100%;">
        <thead>
            <tr>
                <th style="text-align:left; border-bottom:1px solid #ddd; padding:.5rem;">Ad Soyad</th>
                <th style="text-align:left; border-bottom:1px solid #ddd; padding:.5rem;">Cinsiyet</th>
                <th style="text-align:left; border-bottom:1px solid #ddd; padding:.5rem; cursor:pointer"
                    @onclick="ToggleBirthSort">
                    Doğum (Yaş)
                    @if (birthAsc is true)
                    {
                        <span> ▲</span>
                    }
                    else if (birthAsc is false)
                    {

                        <span> ▼</span>
                    }
                </th>
                <th style="text-align:left; border-bottom:1px solid #ddd; padding:.5rem;">Kayıtlanma Tarihi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in data.Items)
            {
                <tr>
                    <td style="border-bottom:1px solid #eee; padding:.5rem;">
                        <a href="@($"/hastalar/{p.Id}")"><b>@p.Ad @p.Soyad</b></a>
                    </td>
                    <td style="border-bottom:1px solid #eee; padding:.5rem;">
                        @(p.Cinsiyet == "E" ? "Erkek" : p.Cinsiyet == "K" ? "Kadın" : "-")
                    </td>
                    <td style="border-bottom:1px solid #eee; padding:.5rem;">
                        @(p.BirthDate?.ToString("dd.MM.yyyy") ?? "-")
                        @if (p.BirthDate is not null)
                        {
                            <span> (@AgePretty(p.BirthDate.Value))</span>
                        }
                    </td>
                    <td style="border-bottom:1px solid #eee; padding:.5rem;">
                        @p.KayitTarihi.ToString("dd.MM.yyyy")
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div style="margin-top:.75rem; display:flex; align-items:center; gap:.5rem;">
        <button type="button" disabled="@(_page <= 1)" @onclick="Prev">Prev</button>
        <span>Sayfa @_page / @TotalPages</span>
        <button type="button" disabled="@(_page >= TotalPages)" @onclick="Next">Next</button>
        <span style="margin-left:.5rem; color:#666;">Toplam: @data.Total</span>
    </div>
}

@code {
    string q = "";
    bool loading;
    string error = "";

    int _page = 1;
    int _pageSize = 25;

    
    bool? birthAsc = null;           
    string? currentSort = "kayittarihi"; 
    

    PagedResult<PatientListDto> data = new() { Items = new() };

    int TotalPages => Math.Max(1, (int)Math.Ceiling((double)(data.Total) / Math.Max(1, _pageSize)));

    protected override async Task OnInitializedAsync() => await Load();
    CancellationTokenSource? _searchCts;

    async Task OnSearchInput(ChangeEventArgs e)
    {
        q = (string?)e.Value ?? "";
        if (string.IsNullOrWhiteSpace(q) || q.Trim().Length < 2)
        {
            _page = 1;
            await Load();
            return;
        }

        _searchCts?.Cancel();
        var cts = new CancellationTokenSource();
        _searchCts = cts;

        try
        {
            await Task.Delay(300, cts.Token);
            _page = 1;
            await Load();
        }
        catch (TaskCanceledException) { }
    }

    async Task Load()
    {
        loading = true; error = "";
        try
        {
            data = await Api.GetPatientsPagedAsync(
                _page, _pageSize, q ?? "", currentSort, birthAsc ?? true);

            if (data.Items is null) data.Items = new();
            if (data.Total == 0) data.Total = data.Items.Count;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            data = new() { Items = new(), Page = _page, PageSize = _pageSize, Total = 0 };
        }
        finally { loading = false; }
    }

    async Task ToggleBirthSort()
    {
        if (birthAsc is null)
            birthAsc = true;
        else
            birthAsc = !birthAsc;

        currentSort = "birthdate";
        _page = 1; 
        await Load(); 
    }


    string AgePretty(DateTime birth)
    {
        var today = DateTime.Today;
        int y = today.Year - birth.Year;
        int m = today.Month - birth.Month;
        int d = today.Day - birth.Day;
        if (d < 0) { m--; var prev = today.AddMonths(-1); d += DateTime.DaysInMonth(prev.Year, prev.Month); }
        if (m < 0) { y--; m += 12; }
        return $"{y}y {m}ay {d}g";
    }

    async Task Search() { _page = 1; await Load(); }
    async Task Prev() { if (_page > 1) { _page--; await Load(); } }
    async Task Next() { if (_page < TotalPages) { _page++; await Load(); } }

    void GoDetail(int id) => Nav.NavigateTo($"/hastalar/{id}");

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = Search();
    }


}
